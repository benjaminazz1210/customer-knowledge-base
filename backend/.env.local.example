# ===== Local-only backend profile =====
# Copy this file to backend/.env when you want to run the project with local
# Ollama + local embedding.
#
# 常见启动方式：
# 1) 直接复制本模板并严格离线启动（推荐）
#    cp backend/.env.local.example backend/.env
#    HF_HUB_OFFLINE=1 TRANSFORMERS_OFFLINE=1 \
#      /Users/benjaminz/miniforge3/envs/daily_3_9/bin/python \
#      -m uvicorn app.main:app --port 8001
#
# 2) 使用一键切换脚本切到本地默认档
#    python3 scripts/switch_profile.py local --file backend/.env
#
# 3) 如果机器资源紧张，切到本地保守档
#    python3 scripts/switch_profile.py local-safe --file backend/.env
#
# 4) 如果你确认本地视觉模型可用，再切到视觉档
#    python3 scripts/switch_profile.py local-vision --file backend/.env
#
# 本地运行前建议确认：
# - Ollama 服务已启动，且 `ollama list` 中至少有 `qwen2.5:14b`
# - 本地 Hugging Face 缓存已具备 `Qwen/Qwen3-VL-Embedding-2B`
# - Qdrant 已在 `localhost:6333` 可访问
#
# 说明：
# - 本模板默认关闭 vision，优先保证本地启动稳定性
# - 若严格离线启动失败，优先检查本地 embedding 缓存是否完整

# ===== LLM (Ollama) =====
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434/v1

# ===== Embedding (local Hugging Face cache) =====
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B
VECTOR_DIMENSION=1024

# ===== Parser / Vision =====
DOCUMENT_PARSER_BACKEND=unstructured
VISION_ENABLED=false
VISION_MODEL=llama3.2-vision:latest
VISION_MAX_IMAGES=20
LLAMA_CLOUD_API_KEY=

# ===== Vector/Search =====
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=nexusai_knowledge_base
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
WORKFLOW_HYBRID_ALPHA=0.7
WORKFLOW_MAX_CONTEXT_CHUNKS=8

# ===== Workflow =====
WORKFLOW_OUTPUT_DIR=generated
WORKFLOW_TEMPLATE_DIR=assets/templates

# ===== Server =====
PORT=8001
DEBUG=true
