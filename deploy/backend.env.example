# ===== LLM provider =====
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# ===== Embedding =====
EMBEDDING_BACKEND=mock
EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=qwen3-vl-embedding
VECTOR_DIMENSION=1024

# ===== Parser / Vision =====
DOCUMENT_PARSER_BACKEND=auto
VISION_ENABLED=false
VISION_MODEL=gpt-4o-mini
VISION_MAX_IMAGES=20
LLAMA_CLOUD_API_KEY=

# ===== Vector/Search =====
COLLECTION_NAME=nexusai_knowledge_base
COLLECTION_ALIAS_NAME=nexusai_knowledge_base_active
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNKING_STRATEGY=fixed
SEMANTIC_CHUNK_MIN_SIZE=200
SEMANTIC_CHUNK_MAX_SIZE=2000
PARENT_CHUNK_SIZE=2000
CHILD_CHUNK_SIZE=400
WORKFLOW_HYBRID_ALPHA=0.7
WORKFLOW_MAX_CONTEXT_CHUNKS=8

# ===== RAG Upgrades =====
RERANKER_ENABLED=false
RERANKER_BACKEND=mock
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=20
RERANKER_TOP_K=5
QUERY_TRANSFORM_ENABLED=false
QUERY_TRANSFORM_STRATEGY=rewrite
MULTI_QUERY_COUNT=3
LOW_CONFIDENCE_ENABLED=false
LOW_CONFIDENCE_STRATEGY=score_threshold
LOW_CONFIDENCE_THRESHOLD=0.35
GUARDRAILS_ENABLED=false
GUARDRAILS_BACKEND=rule_based
OBSERVABILITY_ENABLED=false

# ===== Graph / Admin =====
GRAPH_RAG_ENABLED=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
ADMIN_API_KEY=dev-admin-key
FEEDBACK_TTL_DAYS=90

# ===== Server =====
DEBUG=false
